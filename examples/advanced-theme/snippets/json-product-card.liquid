{%- comment -%}
  JSON Product Card Snippet
  Renders JSON-LD structured data for SEO.
  All data is Liquid-rendered for SSR.

  Parameters:
  - product: Product object
{%- endcomment -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{- product.title | json -}},
  "image": [
    {% for image in product.images limit: 5 %}
      {{- image | image_url: width: 800 | json -}}{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "description": {{- product.description | strip_html | truncate: 160 | json -}},
  "sku": {{- product.selected_or_first_available_variant.sku | json -}},
  "brand": {
    "@type": "Brand",
    "name": {{- product.vendor | json -}}
  },
  "offers": {
    "@type": "Offer",
    "url": {{- shop.url | append: product.url | json -}},
    "priceCurrency": {{- cart.currency.iso_code | json -}},
    "price": {{- product.price | divided_by: 100.0 | json -}},
    "priceValidUntil": "{{- 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' -}}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition"
  }
}
</script>
