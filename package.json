{
  "name": "liquivelte-v4",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite/plugin.ts",
    "./compiler/*": "./src/compiler/*.ts",
    "./runtime/*": "./src/runtime/*.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run --update",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "latest",
    "@types/node": "latest",
    "svelte": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
