<script>
  import section from 'theme';
  import ImageWithCard from './blocks/image-with-card.liquivelte';
</script>

<div class="slider-general">
  {% for block in section.blocks %}
    {% if block.type == 'image-card' and forloop.index == 1 %}
      <ImageWithCard block="{{- block -}}" forloop="{{- forloop -}}">
        <span slot="eyebrow">{{- block.settings.eyebrow -}}</span>
        <p>{{- block.settings.body | html -}}</p>
      </ImageWithCard>
    {% elsif block.type == 'image-card' %}
      <ImageWithCard block="{{- block -}}" forloop="{{- forloop -}}" />
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Slider general",
  "blocks": [{ "type": "image-card", "name": "Image card" }]
}
{% endschema %}
